---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/site/Section.astro";
import WritingCard from "@/components/site/WritingCard.astro";
import Footer from "@/components/site/Footer.astro";
import Experience from "@/components/site/Experience.astro";
import BackgroundFX from "@/components/site/BackgroundFX.astro";
import Navbar from "@/components/site/Navbar.astro";
import ArticleThumbnail from "@/components/site/ArticleThumbnail.astro";
import ProjectList from "@/components/site/ProjectList.astro";
import { getSubstackArticles } from "@/data/substack";
import { getArticleVisual } from "@/lib/article-visuals";
import Image from "astro/components/Image.astro";

const latestArticles = await getSubstackArticles(4);
const featuredArticle = latestArticles[0];
const remainingArticles = latestArticles.slice(1, 4);
const featuredArticleVisual = featuredArticle
  ? getArticleVisual(featuredArticle.title, featuredArticle.href)
  : null;
const formatDate = (value: string) =>
  new Date(value).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
const highlights = [
  "Teach Lead, Orcta",
  "Software Engineer",
  "Democratize tech access",
  "Craft scalable systems",
  "Deep work",
  "Pan-Africanism",
  "Kindness",
];
---

<BaseLayout
  title="Bernard Katamanso"
  description="Engineer and Pan-Africanist building purposeful systems and tools. Writing on tech, deep work, and African innovation."
  image="/og-image.png"
>
  <div class="min-h-screen bg-background text-foreground font-sans" id="home">
    <Navbar />
    <BackgroundFX />
    <main
      id="main-content"
      class="max-w-6xl mx-auto px-4 sm:px-6 py-6 mt-4 font-sans"
    >
      <Section id="about">
        <div class="flex flex-col md:flex-row gap-8 md:gap-12">
          <div class="flex-1 flex flex-col space-y-6 mt-4">
            <p class="max-w-2xl text-2xl text-muted-foreground">
              Engineer & Pan-Africanist 🇬🇭
            </p>
            <div class="space-y-4 mt-3 leading-relaxed">
              <p>
                I build purposeful systems and tools that solve real problems. I
                focus on mastery, deep work, and creating high-impact solutions
                that put Africa at the forefront of global tech.
              </p>
              <p>
                Every problem is a chance to innovate, learn, and craft better
                solutions. I’m passionate about leveraging technology to create
                meaningful impact across Africa and beyond.
              </p>
            </div>

            <aside class="space-y-3 mt-8">
              <h3 class="font-medium">Highlights</h3>
              <div class="flex flex-wrap gap-2">
                {
                  highlights.map((fact) => (
                    <span class="inline-flex items-center rounded-full border px-2.5 py-2 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 text-foreground border-border bg-background hover:bg-accent hover:text-accent-foreground">
                      {fact}
                    </span>
                  ))
                }
              </div>
            </aside>
          </div>

          <div class="shrink-0 w-full md:w-80">
            <picture>
              <source
                type="image/webp"
                srcset="/profile-hero-320.webp 320w, /profile-hero-640.webp 640w"
                sizes="(max-width: 768px) 100vw, 320px"
              />
              <Image
                src="/profile-hero-320.jpg"
                srcset="/profile-hero-320.jpg 320w, /profile-hero-640.jpg 640w"
                sizes="(max-width: 768px) 100vw, 320px"
                width="320"
                height="480"
                alt="Bernard Katamanso portrait"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="h-auto w-full rounded-lg object-cover"
              />
            </picture>
          </div>
        </div>
      </Section>

      <Section id="projects">
        <ProjectList />
      </Section>

      <Section id="writing">
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-2xl font-medium tracking-tight">Writing</h2>
          <a
            href="/writing/"
            class="text-sm text-muted-foreground hover:text-foreground transition-colors"
          >
            See all →
          </a>
        </div>
        <div class="space-y-6">
          {
            featuredArticle && featuredArticleVisual && (
              <a
                href={featuredArticle.href}
                target="_blank"
                rel="noreferrer"
                class="group block border border-border/60 rounded-md overflow-hidden transition-colors hover:border-border"
              >
                <div class="grid gap-4 md:grid-cols-[180px_1fr]">
                  <div class="relative h-32 sm:h-36 md:h-full bg-muted/40 [&_img]:h-full [&_img]:w-full [&_img]:object-cover">
                    <ArticleThumbnail
                      basePath={featuredArticleVisual.basePath}
                      alt={featuredArticleVisual.alt}
                      sizes="(max-width: 768px) 100vw, 180px"
                    />
                  </div>
                  <div class="px-4 py-4 md:px-5 md:py-5">
                    <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">
                      Latest from Substack
                    </p>
                    <h3 class="mt-2 text-lg font-semibold tracking-tight group-hover:text-primary transition-colors">
                      {featuredArticle.title}
                    </h3>
                    <p class="mt-2 text-sm text-muted-foreground line-clamp-2">
                      {featuredArticle.excerpt}
                    </p>
                    <div class="mt-3 flex items-center gap-3 text-xs text-muted-foreground">
                      <span>{formatDate(featuredArticle.date)}</span>
                      {featuredArticle.readTime && (
                        <span>{featuredArticle.readTime}</span>
                      )}
                    </div>
                  </div>
                </div>
              </a>
            )
          }
          <div>
            {
              remainingArticles.map((article) => (
                <WritingCard
                  title={article.title}
                  date={article.date}
                  excerpt={article.excerpt}
                  href={article.href}
                  readTime={article.readTime}
                  image={article.image}
                />
              ))
            }
          </div>
        </div>
      </Section>

      <Experience />

      <Section id="substack">
        <div
          class="p-6 hidden rounded-2xl bg-black/2 dark:text-white backdrop-blur-lg border border-white/10 max-w-3xl mx-auto my-12 text-center flex-row flex-wrap items-center justify-center gap-8"
        >
        </div>
      </Section>
    </main>
    <Footer />
  </div>
</BaseLayout>
