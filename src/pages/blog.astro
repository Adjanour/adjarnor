---
import { getCollection } from "astro:content"
import ArticleCard from "@/components/blog/ArticleCard.astro"
import Footer from "@/components/site/Footer.astro"
import BaseLayout from "@/layouts/BaseLayout.astro"
import { estimateReadTime } from "@/utils/reading-time"

const allArticles = await getCollection("blog", ({ data }) => !data.draft)
const sorted = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const articlesByYear = sorted.reduce<Record<number, typeof sorted>>((acc, article) => {
  const year = article.data.date.getFullYear()
  if (!acc[year]) acc[year] = []
  acc[year].push(article)
  return acc
}, {})

const years = Object.keys(articlesByYear)
  .map(Number)
  .sort((a, b) => b - a)
---

<BaseLayout
  title="Blog | Bernard Katamanso"
  description="Technical writing on software engineering, systems, and AI."
>
  <div class="min-h-screen bg-background text-foreground font-sans">
    <main id="main-content" class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
      <header class="mb-16">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
        >
          <svg
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7" />
            <path d="M19 12H5" />
          </svg>
          Back home
        </a>

        <h1 class="text-3xl font-medium tracking-tight mb-4">Blog</h1>
        <p class="text-muted-foreground text-lg max-w-xl">
          Technical deep-dives on software engineering, systems architecture, and AI.
        </p>
      </header>

      <div class="space-y-12">
        {years.map((year) => (
          <section>
            <h2 class="text-sm font-medium text-muted-foreground mb-4 sticky top-0 bg-background py-2">
              {year}
            </h2>
            <div class="space-y-0">
              {articlesByYear[year].map((article) => (
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  slug={article.id}
                  readingTime={estimateReadTime(article.body)}
                />
              ))}
            </div>
          </section>
        ))}
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>
