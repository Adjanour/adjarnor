---
import { border, createDiagram, fg, fgMuted, muted, primary } from "@/utils/diagram"

const d = createDiagram(520, 340)
const R = 18

interface Node {
  x: number
  y: number
  label: string
  isEnd: boolean
}

// Layout: root → "Elvis" → "Presley" → "film.actor.film" → "Blue_Hawaii"
//         root → "The" → "president"
const nodes: Node[] = [
  { x: 260, y: 30, label: "", isEnd: false },
  { x: 160, y: 100, label: "Elvis", isEnd: false },
  { x: 380, y: 100, label: "The", isEnd: false },
  { x: 160, y: 170, label: "Presley", isEnd: false },
  { x: 380, y: 170, label: "president", isEnd: true },
  { x: 160, y: 240, label: "film.actor.film", isEnd: false },
  { x: 160, y: 310, label: "Blue_Hawaii", isEnd: true },
]

const edges: [number, number][] = [
  [0, 1],
  [0, 2],
  [1, 3],
  [2, 4],
  [3, 5],
  [5, 6],
]

for (const [from, to] of edges) {
  const fy = nodes[from].y + (nodes[from].label === "" ? 6 : R)
  const ty = nodes[to].y - R
  d.svg.appendChild(
    d.rough.line(nodes[from].x, fy, nodes[to].x, ty, {
      stroke: border,
      roughness: 0.4,
      strokeWidth: 1.5,
      seed: from * 10 + to,
    }),
  )
}

for (const n of nodes) {
  if (n.label === "") {
    d.svg.appendChild(
      d.rough.circle(n.x, n.y, 12, {
        fill: muted,
        stroke: border,
        roughness: 0.4,
        seed: 200,
        strokeWidth: 1.5,
      }),
    )
    continue
  }

  const textW = n.label.length * 7.5
  const boxW = Math.max(textW + 20, 36)
  const boxH = 30

  d.svg.appendChild(
    d.rough.rectangle(n.x - boxW / 2, n.y - boxH / 2, boxW, boxH, {
      fill: muted,
      stroke: border,
      roughness: 0.5,
      seed: n.x + n.y,
      strokeWidth: 1.5,
    }),
  )

  if (n.isEnd) {
    d.svg.appendChild(
      d.rough.rectangle(n.x - boxW / 2, n.y - boxH / 2, boxW, boxH, {
        fill: primary,
        stroke: primary,
        roughness: 0.3,
        seed: n.x + n.y + 100,
        strokeWidth: 1.5,
      }),
    )
  }

  d.text(n.x, n.y + 1, n.label, {
    fill: n.isEnd ? "#fff" : fg,
    fontSize: 12,
    fontWeight: n.isEnd ? "700" : "600",
    anchor: "middle",
  })
}

const svgContent = d.serialize()
---

<Fragment set:html={svgContent} />

<style>
  svg {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5em auto;
  }
</style>
