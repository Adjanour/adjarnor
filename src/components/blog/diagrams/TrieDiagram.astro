---
import { border, createDiagram, fg, fgMuted, muted, primary } from "@/utils/diagram"

const d = createDiagram(480, 340)

// Node data: [x, y, char, isEnd]
const nodes: [number, number, string, boolean][] = [
  [240, 30, "", false],
  [160, 90, "c", false],
  [320, 90, "d", false],
  [160, 150, "a", false],
  [280, 150, "o", false],
  [400, 150, "e", false],
  [160, 210, "r", false],
  [280, 210, "g", true],
  [400, 210, "e", false],
  [100, 270, "d", true],
  [220, 270, "e", true],
  [400, 270, "r", true],
]

const edges: [number, number][] = [
  [0, 1], [0, 2],
  [1, 3],
  [2, 4], [2, 5],
  [3, 6],
  [4, 7],
  [5, 8],
  [6, 9], [6, 10],
  [8, 11],
]

const R = 16

// Edges
for (const [from, to] of edges) {
  const [x1, y1] = [nodes[from][0], nodes[from][1] + R]
  const [x2, y2] = [nodes[to][0], nodes[to][1] - R]
  d.svg.appendChild(
    d.rough.line(x1, y1, x2, y2, {
      stroke: border,
      roughness: 0.4,
      strokeWidth: 1.5,
      seed: from * 10 + to,
    }),
  )
}

// Nodes
for (const [x, y, char, isEnd] of nodes) {
  if (char === "") {
    // root — small filled circle
    d.svg.appendChild(
      d.rough.circle(x, y, 12, {
        fill: muted,
        stroke: border,
        roughness: 0.4,
        seed: 200,
        strokeWidth: 1.5,
      }),
    )
    continue
  }

  d.svg.appendChild(
    d.rough.circle(x, y, R * 2, {
      fill: muted,
      stroke: border,
      roughness: 0.5,
      seed: x + y,
      strokeWidth: 1.5,
    }),
  )

  if (isEnd) {
    d.svg.appendChild(
      d.rough.circle(x, y, 9, {
        fill: primary,
        stroke: "transparent",
        roughness: 0.3,
        seed: x + y + 100,
      }),
    )
  }

  d.text(x, y + 1, char, {
    fill: fg,
    fontSize: 13,
    fontWeight: "600",
    anchor: "middle",
  })
}

const svgContent = d.serialize()
---

<Fragment set:html={svgContent} />

<style>
  svg {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5em auto;
  }
</style>
