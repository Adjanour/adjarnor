---
interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props
const filtered = headings.filter((h) => h.depth <= 3)
---

{
  filtered.length >= 2 && (
    <nav class="toc-sidebar">
      <h2 class="toc-sidebar-heading">On this page</h2>
      <ul class="toc-sidebar-list">
        {filtered.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class="toc-sidebar-link"
              style={{ marginLeft: `${(h.depth - 2) * 0.75}em` }}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  const links = document.querySelectorAll(".toc-sidebar-link")
  const ids = []

  for (const link of links) {
    const href = link.getAttribute("href")
    if (href) ids.push(href.slice(1))
  }

  function onScroll() {
    let current = ""
    for (const id of ids) {
      const el = document.getElementById(id)
      if (el && el.getBoundingClientRect().top <= 120) {
        current = id
      }
    }

    for (const link of links) {
      const href = link.getAttribute("href")
      if (href === `#${current}`) {
        link.classList.add("active")
      } else {
        link.classList.remove("active")
      }
    }
  }

  if (ids.length > 0) {
    onScroll()
    window.addEventListener("scroll", onScroll, { passive: true })
  }
</script>
