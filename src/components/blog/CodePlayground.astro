---
interface Props {
  code: string
}

const { code } = Astro.props
---

<div class="my-6 rounded-lg overflow-hidden not-prose" style="background:#0d1117">
  <div class="relative">
    <textarea
      class="code-playground-input font-mono"
      style="width:100%;min-height:110px;background:transparent;border:none;color:#e6edf3;font-size:14px;line-height:1.6;resize:vertical;tab-size:2;outline:none;padding:16px 20px"
      spellcheck="false"
    >{code}</textarea>
    <button
      class="code-playground-run absolute top-2 right-2 inline-flex items-center justify-center w-6 h-6 rounded text-xs bg-[#2d333b] hover:bg-[#3d444d] text-[#e6edf3] transition-colors opacity-60 hover:opacity-100"
      aria-label="Run code"
    >
      <svg viewBox="0 0 16 16" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true">
        <path d="M4 2.5v11l9-5.5z" />
      </svg>
    </button>
  </div>
  <div
    class="code-playground-output hidden font-mono text-sm leading-relaxed whitespace-pre-wrap"
    style="color:#e6edf3;padding:16px 20px;border-top:1px solid rgba(255,255,255,0.08);min-height:0"
  ></div>
</div>

<script>
  const playgrounds = document.querySelectorAll(".code-playground-run")

  for (const runBtn of playgrounds) {
    const container = runBtn.closest(".my-6")
    const textarea: HTMLTextAreaElement = container.querySelector(".code-playground-input")
    const output: HTMLElement = container.querySelector(".code-playground-output")
    const originalCode = textarea.value

    runBtn.addEventListener("click", () => {
      output.classList.remove("hidden")
      const logs: string[] = []
      const mockConsole = {
        log: (...args: unknown[]) => {
          logs.push(args.map((a) => (typeof a === "object" ? JSON.stringify(a, null, 2) : String(a))).join(" "))
        },
        error: (...args: unknown[]) => {
          logs.push("Error: " + args.map(String).join(" "))
        },
        warn: (...args: unknown[]) => {
          logs.push("Warning: " + args.map(String).join(" "))
        },
      }

      try {
        const fn = new Function("console", textarea.value)
        fn(mockConsole)
        output.textContent = logs.join("\n") || "(no output)"
        output.style.color = "#e6edf3"
      } catch (e) {
        output.textContent = "Error: " + (e as Error).message
        output.style.color = "#f87171"
      }
    })

    textarea.addEventListener("input", () => {
      if (textarea.value !== originalCode) {
        output.classList.add("hidden")
        output.textContent = ""
      }
    })
  }
</script>
