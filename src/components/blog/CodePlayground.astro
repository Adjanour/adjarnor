---
interface Props {
  code: string
  title?: string
}

const { code, title = "Interactive example" } = Astro.props
const lineCount = code.split("\n").length
---

<div
  class="code-playground my-6 rounded-lg overflow-hidden not-prose"
  role="region"
  aria-label={title}
>
  <div class="flex items-center justify-between px-3 py-1.5 border-b" style="border-color:inherit">
    <span class="text-[11px] font-medium opacity-60">{title}</span>
    <kbd class="text-[10px] opacity-40 hidden sm:inline">Ctrl+Enter</kbd>
  </div>
  <div class="relative">
    <div class="flex">
      <div
        class="code-playground-lines select-none text-right pr-3 pt-[16px] text-xs leading-[1.7] opacity-25 font-mono"
        style="min-width:2.5em"
        aria-hidden="true"
      >
        {Array.from({ length: lineCount }, (_, i) => i + 1).join("\n")}
      </div>
      <textarea
        class="code-playground-input font-mono flex-1"
        style="width:100%;min-height:110px;background:transparent;border:none;font-size:15px;line-height:1.7;resize:vertical;tab-size:2;outline:none;padding:16px 0 16px 0"
        spellcheck="false"
        autocapitalize="off"
        autocomplete="off"
        autocorrect="off"
        aria-label="Editable code example"
      >{code}</textarea>
    </div>
    <button
      class="code-playground-run absolute bottom-2 right-2 inline-flex items-center gap-1 px-2 py-1 rounded text-xs font-medium transition-all opacity-0 group-hover:opacity-100 focus-visible:opacity-100"
      aria-label="Run code (Ctrl+Enter)"
    >
      <svg viewBox="0 0 16 16" class="w-3 h-3" fill="currentColor" aria-hidden="true">
        <path d="M4 2.5v11l9-5.5z" />
      </svg>
      Run
    </button>
  </div>
  <div
    class="code-playground-output font-mono text-sm leading-relaxed whitespace-pre-wrap"
    style="padding:12px 20px 12px 20px;border-top:1px solid;min-height:0"
    role="log"
    aria-live="polite"
    aria-label="Code output"
  ></div>
</div>

<script>
  const playgrounds = document.querySelectorAll<HTMLElement>(".code-playground")

  for (const container of playgrounds) {
    const textarea: HTMLTextAreaElement = container.querySelector(".code-playground-input")
    const output: HTMLElement = container.querySelector(".code-playground-output")
    const runBtn: HTMLElement = container.querySelector(".code-playground-run")
    const lines: HTMLElement = container.querySelector(".code-playground-lines")
    const originalCode = textarea.value

    output.style.display = "none"

    function updateLineNumbers() {
      if (!lines) return
      const count = textarea.value.split("\n").length
      lines.textContent = Array.from({ length: count }, (_, i) => i + 1).join("\n")
    }

    function run() {
      output.style.display = ""
      output.classList.remove("hidden")
      output.setAttribute("aria-busy", "true")

      const logs: string[] = []
      const mockConsole = {
        log: (...args: unknown[]) => {
          logs.push(args.map((a) => (typeof a === "object" ? JSON.stringify(a, null, 2) : String(a))).join(" "))
        },
        error: (...args: unknown[]) => {
          logs.push("Error: " + args.map(String).join(" "))
        },
        warn: (...args: unknown[]) => {
          logs.push("Warning: " + args.map(String).join(" "))
        },
      }

      try {
        const fn = new Function("console", textarea.value)
        fn(mockConsole)
        output.textContent = logs.join("\n") || "(no output)"
        output.style.color = ""
      } catch (e) {
        output.textContent = "Error: " + (e as Error).message
        output.style.color = ""
      }

      output.setAttribute("aria-busy", "false")
    }

    runBtn.addEventListener("click", run)

    textarea.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Tab") {
        e.preventDefault()
        const start = textarea.selectionStart
        const end = textarea.selectionEnd
        textarea.value = textarea.value.substring(0, start) + "  " + textarea.value.substring(end)
        textarea.selectionStart = textarea.selectionEnd = start + 2
        updateLineNumbers()
        return
      }

      if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
        e.preventDefault()
        run()
      }
    })

    textarea.addEventListener("input", () => {
      updateLineNumbers()
      if (textarea.value !== originalCode) {
        output.style.display = "none"
        output.textContent = ""
      }
    })
  }
</script>
