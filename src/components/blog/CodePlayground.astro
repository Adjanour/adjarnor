---
interface Props {
  code: string
  title?: string
}

const { code, title = "Interactive example" } = Astro.props
---

<div
  class="pg not-prose"
  role="region"
  aria-label={title}
>
  <div class="pg-header">
    <span class="pg-title">{title}</span>
    <div class="pg-actions">
      <span class="pg-hint" aria-live="polite">Ctrl+Enter to run</span>
      <button class="pg-btn pg-reset" title="Reset to original">
        <svg viewBox="0 0 16 16" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true">
          <path d="M2 2.5v5h5M14 13.5v-5H9" stroke="currentColor" stroke-width="1.5" fill="none" />
          <path d="M13.05 5.5a6 6 0 0 0-10.53-1.47L2 4.5M2 11.5l.52.47a6 6 0 0 0 10.53-1.47" stroke="currentColor" stroke-width="1.5" fill="none" />
        </svg>
        Reset
      </button>
      <button class="pg-btn run pg-run" aria-label="Run code (Ctrl+Enter)">
        <svg viewBox="0 0 16 16" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true">
          <path d="M4 2.5v11l9-5.5z" />
        </svg>
        Run
      </button>
    </div>
  </div>
  <div class="pg-editor">
    <div class="pg-lines" aria-hidden="true">1</div>
    <textarea
      class="pg-textarea"
      spellcheck="false"
      autocapitalize="off"
      autocomplete="off"
      autocorrect="off"
      aria-label="Editable code"
      style="resize:none"
    >{code}</textarea>
  </div>
  <div class="pg-output empty" role="log" aria-live="polite" aria-label="Code output">
    Run your code to see output here.
  </div>
</div>

<style>
  .pg {
    border: 1px solid hsl(var(--border));
    border-radius: 8px;
    overflow: hidden;
    font-family: var(--font-mono);
    background: hsl(var(--background));
  }
  .pg-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid hsl(var(--muted));
    background: hsl(var(--muted) / 0.3);
  }
  .pg-title {
    font-size: 13px;
    color: hsl(var(--muted-foreground));
    font-family: var(--font-sans);
  }
  .pg-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .pg-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--background));
    font-size: 12px;
    font-family: var(--font-sans);
    color: hsl(var(--foreground));
    cursor: pointer;
    transition: background 0.1s;
  }
  .pg-btn:hover {
    background: hsl(var(--muted) / 0.5);
  }
  .pg-btn.run {
    background: hsl(var(--foreground));
    color: hsl(var(--background));
    border-color: transparent;
  }
  .pg-btn.run:hover {
    opacity: 0.85;
  }
  .pg-btn.run:active {
    transform: scale(0.97);
  }
  .pg-editor {
    display: flex;
    position: relative;
  }
  .pg-lines {
    padding: 14px 10px 14px 14px;
    font-size: 13px;
    line-height: 1.65;
    color: hsl(var(--muted-foreground) / 0.4);
    text-align: right;
    user-select: none;
    white-space: pre;
  }
  .pg-textarea {
    flex: 1;
    border: none;
    outline: none;
    resize: none;
    font-size: 15px;
    line-height: 1.65;
    padding: 14px 14px 14px 0;
    background: transparent;
    color: hsl(var(--foreground));
    font-family: var(--font-mono);
    tab-size: 2;
    caret-color: hsl(var(--foreground));
    min-height: 100px;
    width: 100%;
  }
  .pg-textarea::placeholder {
    color: hsl(var(--muted-foreground) / 0.5);
  }
  .pg-output {
    font-size: 12.5px;
    line-height: 1.6;
    padding: 10px 16px;
    border-top: 1px solid hsl(var(--muted));
    white-space: pre-wrap;
    font-family: var(--font-mono);
  }
  .pg-output.ok {
    color: hsl(var(--primary));
  }
  .pg-output.err {
    color: hsl(var(--destructive));
  }
  .pg-output.empty {
    color: hsl(var(--muted-foreground) / 0.6);
    font-family: var(--font-sans);
    font-size: 12px;
  }
  .pg-hint {
    font-size: 11px;
    color: hsl(var(--muted-foreground) / 0.6);
    font-family: var(--font-sans);
  }
</style>

<script>
  const playgrounds = document.querySelectorAll<HTMLElement>(".pg")

  for (const container of playgrounds) {
    const textarea: HTMLTextAreaElement = container.querySelector(".pg-textarea")
    const lines: HTMLElement = container.querySelector(".pg-lines")
    const output: HTMLElement = container.querySelector(".pg-output")
    const runBtn: HTMLElement = container.querySelector(".pg-run")
    const resetBtn: HTMLElement = container.querySelector(".pg-reset")
    const hint: HTMLElement = container.querySelector(".pg-hint")
    const original = textarea.value

    function syncLines() {
      const count = textarea.value.split("\n").length
      lines.textContent = Array.from({ length: count }, (_, i) => i + 1).join("\n")
    }

    function run() {
      const logs: string[] = []
      const mock = {
        log: (...args: unknown[]) => {
          logs.push(args.map((x) => (typeof x === "object" ? JSON.stringify(x, null, 2) : String(x))).join(" "))
        },
        error: (...args: unknown[]) => {
          logs.push("[error] " + args.map(String).join(" "))
        },
        warn: (...args: unknown[]) => {
          logs.push("[warn] " + args.map(String).join(" "))
        },
      }
      try {
        new Function("console", textarea.value)(mock)
        output.className = "pg-output " + (logs.length ? "ok" : "empty")
        output.textContent = logs.join("\n") || "No output \u2014 try adding a console.log()"
      } catch (e) {
        const err = e as Error
        output.className = "pg-output err"
        const lineMatch = err.stack?.match(/(?::\d+):(\d+)/)
        output.textContent = "\u2717 " + err.message + (lineMatch ? " (line " + lineMatch[1] + ")" : "")
      }
    }

    function syncReset() {
      const dirty = textarea.value !== original
      resetBtn.style.opacity = dirty ? "1" : "0.35"
      resetBtn.style.pointerEvents = dirty ? "auto" : "none"
      hint.textContent = dirty ? "Ctrl+Enter to run" : "Edit the code above"
    }

    syncLines()
    syncReset()

    textarea.addEventListener("input", () => {
      syncLines()
      syncReset()
      output.className = "pg-output empty"
      output.textContent = "Run your code to see output here."
    })

    textarea.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Tab") {
        e.preventDefault()
        const s = textarea.selectionStart
        textarea.value = textarea.value.slice(0, s) + "  " + textarea.value.slice(textarea.selectionEnd)
        textarea.selectionStart = textarea.selectionEnd = s + 2
        syncLines()
        return
      }
      if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
        e.preventDefault()
        run()
      }
    })

    runBtn.addEventListener("click", run)

    resetBtn.addEventListener("click", () => {
      textarea.value = original
      syncLines()
      syncReset()
      output.className = "pg-output empty"
      output.textContent = "Run your code to see output here."
      textarea.focus()
    })
  }
</script>
