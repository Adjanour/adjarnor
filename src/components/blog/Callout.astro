---
interface Props {
  type?: "info" | "tip" | "warning" | "danger"
}

const { type = "info" } = Astro.props

const borderColors: Record<string, string> = {
  info: "border-l-[hsl(var(--primary))]",
  tip: "border-l-[hsl(158,60%,42%)]",
  warning: "border-l-[hsl(37,75%,45%)]",
  danger: "border-l-[hsl(0,70%,55%)]",
}

const labels: Record<string, string> = {
  info: "Note",
  tip: "Tip",
  warning: "Caution",
  danger: "Watch out",
}
---

<aside class={`border-l-2 pl-4 py-2 my-6 text-sm text-muted-foreground bg-muted/30 rounded-r-sm ${borderColors[type]}`}>
  <span class="text-xs font-medium uppercase tracking-wider text-foreground/60">{labels[type]}</span>
  <div class="mt-1"><slot /></div>
</aside>
