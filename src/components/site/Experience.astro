---
interface Role {
  title: string
  org: string
  period: string
  current?: boolean
}

const roles: Role[] = [
  { title: "CTO", org: "Orcta", period: "2024–", current: true },
  { title: "Co-Lead", org: "GDG UMaT", period: "2024–2025" },
  { title: "Co-Founder", org: "Salem Aid Foundation", period: "2022–", current: true },
]
---

<section id="experience" class="mx-auto max-w-5xl px-12 py-16 md:py-10 scroll-mt-24">
  <h2 class="text-2xl font-medium tracking-tight mb-8">Experience</h2>

  <div class="space-y-4">
    {roles.map((role) => (
      <div
        class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 py-2 border-b border-border last:border-b-0"
      >
        <span class="text-xs text-muted-foreground tabular-nums shrink-0 w-24">
          {role.period}
        </span>
        <div class="flex-1 min-w-0">
          <span class="font-medium">{role.title}</span>
          <span class="text-muted-foreground"> at </span>
          <span class="text-muted-foreground">{role.org}</span>
          {role.current && (
            <span class="ml-2 text-xs text-primary">current</span>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
