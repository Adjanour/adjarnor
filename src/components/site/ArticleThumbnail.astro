---
import { Image } from "astro:assets";

interface Props {
  basePath: string;
  alt: string;
  class?: string;
  sizes?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  width?: number;
  height?: number;
}

const {
  basePath,
  alt,
  class: className = "",
  sizes = "96px",
  loading = "lazy",
  fetchpriority,
  width = 320,
  height = 400,
} = Astro.props;
---

<picture>
  <source
    type="image/webp"
    srcset={`${basePath}-320.webp 320w, ${basePath}-640.webp 640w`}
    sizes={sizes}
  />
  <Image
    src={`${basePath}-320.jpg`}
    srcset={`${basePath}-320.jpg 320w, ${basePath}-640.jpg 640w`}
    sizes={sizes}
    width={width}
    height={height}
    alt={alt}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
    class={className}
  />
</picture>
