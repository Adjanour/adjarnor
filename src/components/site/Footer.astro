---
const year = new Date().getFullYear();
---

<footer class="border-t">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-4 py-4 md:flex-row">
    <p class="text-sm text-muted-foreground">
      © {year} Bernard Kirk Adjarnor Katamanso. All rights reserved.
    </p>
    <div class="flex items-center gap-3 font-display">
      <a
        aria-label="Email"
        href="mailto:adjanour@icloud"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m22 7-8.5 5.7a2 2 0 0 1-2.2 0L2 7" />
          <rect width="20" height="16" x="2" y="4" rx="2" />
        </svg>
      </a>
      <a
        aria-label="GitHub"
        href="https://github.com/Adjanour"
        target="_blank"
        rel="noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
        </svg>
      </a>
      <a
        aria-label="LinkedIn"
        href="https://linkedin.com/in/kirk-katamanso"
        target="_blank"
        rel="noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
          <rect width="4" height="12" x="2" y="9" />
          <circle cx="4" cy="4" r="2" />
        </svg>
      </a>
      <a
        aria-label="Twitter"
        href="https://twitter.com/kirk_katamanso"
        target="_blank"
        rel="noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2-2.2-.1-4-1.5-4.6-3.6 1 0 2-.1 3-.4-2.2-.5-3.7-2.4-3.7-4.7.6.3 1.3.5 2 .6C2.5 7.4 2 4.8 3.4 2.9c2.2 2.7 5.5 4.4 9.2 4.6-.7-3 1.6-5.7 4.7-5.7 1.3 0 2.5.5 3.4 1.4.9-.2 1.7-.5 2.4-.9z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
