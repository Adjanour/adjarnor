---
interface Props {
  src: string;
  alt: string;
  class?: string;
  placeholder?: string;
  sizes?: string;
  srcSet?: string;
}

const {
  src,
  alt,
  class: className = "",
  placeholder,
  sizes = "100vw",
  srcSet,
} = Astro.props;

const backgroundStyle = placeholder
  ? `background-image: url(${placeholder}); background-size: cover; background-position: center;`
  : undefined;
---

<div class={`relative overflow-hidden ${className}`} style={backgroundStyle}>
  <img
    src={src}
    srcset={srcSet}
    sizes={sizes}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full h-auto object-cover"
  />
</div>
