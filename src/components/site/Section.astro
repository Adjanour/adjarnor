---
interface Props {
  id: string;
  title: string;
  description?: string;
}

const { id, title, description } = Astro.props;
---

<section id={id} aria-labelledby={`${id}-title`} class="scroll-mt-24">
  <div class="mx-auto max-w-5xl px-6 py-14 md:py-14">
    <header class="mb-12 text-center">
      <h2
        id={`${id}-title`}
        class="font-display text-3xl font-semibold tracking-tight md:text-4xl"
      >
        {title}
      </h2>
      {description && (
        <p class="mt-4 mx-auto max-w-2xl text-lg text-muted-foreground">
          {description}
        </p>
      )}
    </header>
    <div class="font-sans max-w-4xl mx-auto">
      <slot />
    </div>
  </div>
</section>
