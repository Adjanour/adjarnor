---
import DynamicElements from "./DynamicElements.astro"
import ThemeToggle from "./ThemeToggle.astro"
---

<header class="fixed top-0 left-0 w-full right-0 z-50 px-3 sm:px-4 pt-4">
  <nav class="mx-auto max-w-6xl backdrop-blur-md bg-background/70 border border-border/40 rounded-[16px] sm:rounded-[18px] px-5 sm:px-8 py-3">
    <div class="flex items-center justify-between gap-4 w-full">
      <a href="#home" class="font-sans text-lg font-semibold tracking-tight hover:text-primary transition-colors shrink-0 whitespace-nowrap">
        Bernard Katamanso
      </a>
      <DynamicElements />
      <div class="flex items-center gap-3 shrink-0">
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
