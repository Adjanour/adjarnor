---
interface Props {
  title: string
  date: string
  excerpt?: string
  href: string
  readTime?: string
  tags?: string[]
  image?: string
}

const { title, date, excerpt, href, readTime, image } = Astro.props
const isExternal = !href.startsWith("#")
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
})
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noreferrer" : undefined}
  class="group block py-5 last:border-b-0 hover:bg-muted/30 -mx-3 px-3 rounded-sm transition-colors"
>
  <article class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
    <div class="flex items-center gap-3 shrink-0">
      <div class="relative h-12 w-12 sm:h-14 sm:w-14 rounded-none overflow-hidden border border-border/60 bg-muted/40">
        {image && (
          <img
            src={image}
            alt=""
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        )}
      </div>
      <time
        datetime={date}
        class="text-xs text-muted-foreground tabular-nums shrink-0 w-24"
      >
        {formattedDate}
      </time>
    </div>

    <div class="flex-1 min-w-0">
      <h3
        class="text-base font-medium text-foreground group-hover:text-primary transition-colors leading-snug"
      >
        {title}
      </h3>

      {excerpt && (
        <p class="text-sm text-muted-foreground mt-1 line-clamp-2">
          {excerpt}
        </p>
      )}
    </div>

    <div
      class="hidden sm:flex items-center gap-1 text-xs text-muted-foreground shrink-0"
    >
      {readTime && <span>{readTime}</span>}
      <svg
        class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </div>
  </article>
</a>
