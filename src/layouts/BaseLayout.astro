---
import "@/index.css"
import { Font } from "astro:assets"

interface Props {
  title?: string
  description?: string
  image?: string
}

const {
  title = "Bernard Katamanso",
  description = "Technical blog on software engineering, systems architecture, developer tooling, and infrastructure by Bernard Katamanso, engineer at Orcta Technologies.",
  image = "/og-image.png",
} = Astro.props

const siteUrl = Astro.site ?? new URL("https://www.adjarnor.dev")
const canonicalPath =
  Astro.url.pathname === "/"
    ? "/"
    : Astro.url.pathname.includes(".") || Astro.url.pathname.endsWith("/")
      ? Astro.url.pathname
      : `${Astro.url.pathname}/`
const canonicalUrl = new URL(canonicalPath, siteUrl)
const ogImage = image.startsWith("http") ? image : new URL(image, siteUrl).toString()
const themeScript = `(() => {
  try {
    const storageKey = "theme";
    const storedTheme = localStorage.getItem(storageKey);
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const theme = storedTheme ?? (prefersDark ? "dark" : "light");
    document.documentElement.classList.toggle("dark", theme === "dark");
    document.documentElement.style.colorScheme = theme;
  } catch {}
})();`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Bernard Kirk Adjarnor Katamanso" />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:logo" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Font cssVariable="--font-body" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-mono" />
    <script is:inline set:html={themeScript}></script>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-md focus:bg-background focus:px-4 focus:py-2 focus:text-foreground focus:shadow"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
